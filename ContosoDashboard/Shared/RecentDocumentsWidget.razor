@using ContosoDashboard.Services.Documents

@* T-046: receives result as parameter — does NOT fetch its own data *@

@if (Documents == null)
{
    <p><em>Loading…</em></p>
}
else if (!Documents.Any())
{
    <p class="text-muted"><i class="bi bi-cloud-slash me-1"></i>Aún no has subido documentos.</p>
}
else
{
    <div class="list-group list-group-flush">
        @foreach (var doc in Documents)
        {
            <a href="/api/documents/@doc.Id/download"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-start px-0 py-2">
                <div>
                    <div class="fw-semibold">@doc.Title</div>
                    <small class="text-muted">
                        @doc.Category.ToString().Replace("_", " ") · @doc.UploadedAtUtc.LocalDateTime.ToString("MMM dd")
                    </small>
                </div>
                <i class="bi bi-download text-muted ms-2 mt-1"></i>
            </a>
        }
    </div>
    <a href="/documents/my" class="btn btn-link btn-sm px-0 mt-2">View all documents →</a>
}

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<DocumentSummary>? Documents { get; set; }
}
