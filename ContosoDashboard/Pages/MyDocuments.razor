@page "/documents/my"
@using ContosoDashboard.Models
@using ContosoDashboard.Services.Documents
@using ContosoDashboard.Services.Documents.Queries
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize]
@inject IMediator Mediator
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>My Documents - ContosoDashboard</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1><i class="bi bi-files"></i> My Documents</h1>
        </div>
        <div class="col-auto">
            <a href="/documents/upload" class="btn btn-primary">
                <i class="bi bi-cloud-upload me-1"></i> Upload
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="row mb-3 g-2">
        <div class="col-md-3">
            <label class="form-label">Category</label>
            <select class="form-select" @bind="filterCategory" @bind:event="onchange">
                <option value="">All categories</option>
                @foreach (var cat in Enum.GetValues<DocumentCategory>())
                {
                    <option value="@((int)cat)">@cat.ToString().Replace("_", " ")</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">From</label>
            <input type="date" class="form-control" @bind="filterFrom" />
        </div>
        <div class="col-md-2">
            <label class="form-label">To</label>
            <input type="date" class="form-control" @bind="filterTo" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-secondary w-100" @onclick="ApplyFilters">
                <i class="bi bi-funnel"></i> Filter
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <p><em>Loading…</em></p>
    }
    else if (result == null || !result.Items.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i>
            No documents found. <a href="/documents/upload">Upload your first document</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th><button class="btn btn-link p-0 text-decoration-none fw-bold" @onclick='() => Sort("title")'>Title @SortIcon("title")</button></th>
                        <th><button class="btn btn-link p-0 text-decoration-none fw-bold" @onclick='() => Sort("category")'>Category @SortIcon("category")</button></th>
                        <th><button class="btn btn-link p-0 text-decoration-none fw-bold" @onclick='() => Sort("uploadDate")'>Uploaded @SortIcon("uploadDate")</button></th>
                        <th><button class="btn btn-link p-0 text-decoration-none fw-bold" @onclick='() => Sort("filesize")'>Size @SortIcon("filesize")</button></th>
                        <th>Project</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in result.Items)
                    {
                        <tr>
                            <td>
                                <strong>@doc.Title</strong>
                                @if (doc.Tags.Any())
                                {
                                    <br />
                                    @foreach (var tag in doc.Tags)
                                    {
                                        <span class="badge bg-secondary me-1">@tag</span>
                                    }
                                }
                            </td>
                            <td><span class="badge bg-info text-dark">@doc.Category.ToString().Replace("_", " ")</span></td>
                            <td><small>@doc.UploadedAtUtc.LocalDateTime.ToString("MMM dd, yyyy HH:mm")</small></td>
                            <td><small>@FormatSize(doc.FileSizeBytes)</small></td>
                            <td><small>@(doc.ProjectName ?? "–")</small></td>
                            <td>
                                <a href="/api/documents/@doc.Id/download" class="btn btn-sm btn-outline-primary me-1" title="Download">
                                    <i class="bi bi-download"></i>
                                </a>
                                <button class="btn btn-sm btn-outline-danger"
                                        title="Delete"
                                        @onclick="() => ConfirmDelete(doc.Id, doc.Title)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Showing @((currentPage - 1) * pageSize + 1)–@Math.Min(currentPage * pageSize, result.TotalCount) of @result.TotalCount
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">‹</button>
                    </li>
                    @for (int p = 1; p <= TotalPages; p++)
                    {
                        var pg = p;
                        <li class="page-item @(pg == currentPage ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                        </li>
                    }
                    <li class="page-item @(currentPage >= TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">›</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Delete confirmation modal -->
@if (deleteTargetId.HasValue)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle"></i> Delete Document</h5>
                </div>
                <div class="modal-body">
                    Are you sure you want to permanently delete <strong>@deleteTargetTitle</strong>?
                    This action cannot be undone.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CancelDelete">Cancel</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<DocumentSummary>? result;
    private bool     isLoading   = true;
    private int      currentPage = 1;
    private int      pageSize    = 20;
    private string   sortBy      = "uploadDate";
    private bool     sortDesc    = true;
    private int      currentUserId = 0;

    // Filters
    private string?       filterCategory;
    private DateTime?     filterFrom;
    private DateTime?     filterTo;

    // Delete confirmation
    private Guid?   deleteTargetId;
    private string? deleteTargetTitle;

    private int TotalPages => result is null ? 1 : (int)Math.Ceiling(result.TotalCount / (double)pageSize);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var claim     = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        if (claim != null) int.TryParse(claim.Value, out currentUserId);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            DocumentCategory? cat = filterCategory is null ? null
                : (DocumentCategory)int.Parse(filterCategory);

            var filter = new DocumentFilter(
                UserId:         currentUserId,
                ProjectId:      null,
                Category:       cat,
                FromUtc:        filterFrom.HasValue ? new DateTimeOffset(filterFrom.Value, TimeSpan.Zero) : null,
                ToUtc:          filterTo.HasValue   ? new DateTimeOffset(filterTo.Value,   TimeSpan.Zero) : null,
                SortBy:         sortBy,
                SortDescending: sortDesc,
                Page:           currentPage,
                PageSize:       pageSize);

            result = await Mediator.Send(new GetMyDocumentsQuery(currentUserId, filter));
        }
        finally { isLoading = false; }
    }

    private async Task ApplyFilters()
    {
        currentPage = 1;
        await LoadAsync();
    }

    private async Task Sort(string field)
    {
        if (sortBy == field) sortDesc = !sortDesc;
        else { sortBy = field; sortDesc = false; }
        currentPage = 1;
        await LoadAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > TotalPages) return;
        currentPage = page;
        await LoadAsync();
    }

    private void ConfirmDelete(Guid id, string title)
    {
        deleteTargetId    = id;
        deleteTargetTitle = title;
    }

    private void CancelDelete()
    {
        deleteTargetId    = null;
        deleteTargetTitle = null;
    }

    private async Task ExecuteDelete()
    {
        if (!deleteTargetId.HasValue) return;
        try
        {
            await Mediator.Send(new ContosoDashboard.Services.Documents.Commands.DeleteDocumentCommand(
                deleteTargetId.Value, currentUserId));
            deleteTargetId = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            CancelDelete();
            // Basic inline error — production would use a toast service
            Console.Error.WriteLine($"Delete failed: {ex.Message}");
        }
    }

    private MarkupString SortIcon(string field)
    {
        if (sortBy != field) return new MarkupString(string.Empty);
        return new MarkupString(sortDesc ? " ↓" : " ↑");
    }

    private static string FormatSize(long bytes) =>
        bytes switch
        {
            < 1_024     => $"{bytes} B",
            < 1_048_576 => $"{bytes / 1_024.0:F1} KB",
            _           => $"{bytes / 1_048_576.0:F1} MB"
        };
}
