@page "/documents/search"
@using ContosoDashboard.Models
@using ContosoDashboard.Services.Documents
@using ContosoDashboard.Services.Documents.Queries
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize]
@inject IMediator Mediator
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Search Documents - ContosoDashboard</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1><i class="bi bi-search"></i> Search Documents</h1>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-8">
            <div class="input-group">
                <input type="text"
                       class="form-control form-control-lg"
                       placeholder="Search in title, description, tags, project…"
                       @bind="searchTerm"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
                <button class="btn btn-primary" @onclick="DoSearch" disabled="@isLoading">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <p><em>Searching…</em></p>
    }
    else if (hasSearched && (result == null || !result.Items.Any()))
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i> No documents found for "<strong>@lastSearchTerm</strong>".
        </div>
    }
    else if (result != null && result.Items.Any())
    {
        <div class="mb-2">
            <small class="text-muted">@result.TotalCount results for "<strong>@lastSearchTerm</strong>"</small>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Uploaded By</th>
                        <th>Date</th>
                        <th>Size</th>
                        <th>Project</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in result.Items)
                    {
                        <tr>
                            <td>
                                <strong>@doc.Title</strong>
                                @if (doc.Tags.Any())
                                {
                                    <br />
                                    @foreach (var tag in doc.Tags)
                                    {
                                        <span class="badge bg-secondary me-1">@tag</span>
                                    }
                                }
                            </td>
                            <td><span class="badge bg-info text-dark">@doc.Category.ToString().Replace("_", " ")</span></td>
                            <td><small>@doc.UploaderName</small></td>
                            <td><small>@doc.UploadedAtUtc.LocalDateTime.ToString("MMM dd, yyyy")</small></td>
                            <td><small>@FormatSize(doc.FileSizeBytes)</small></td>
                            <td><small>@(doc.ProjectName ?? "–")</small></td>
                            <td>
                                <a href="/api/documents/@doc.Id/download" class="btn btn-sm btn-outline-primary" title="Download">
                                    <i class="bi bi-download"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Page @currentPage of @TotalPages
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">‹</button>
                    </li>
                    @for (int p = 1; p <= TotalPages; p++)
                    {
                        var pg = p;
                        <li class="page-item @(pg == currentPage ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                        </li>
                    }
                    <li class="page-item @(currentPage >= TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">›</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@code {
    private string? searchTerm;
    private string? lastSearchTerm;
    private PagedResult<DocumentSummary>? result;
    private bool isLoading  = false;
    private bool hasSearched = false;
    private int  currentPage = 1;
    private int  pageSize    = 20;
    private int  currentUserId = 0;

    private int TotalPages => result is null ? 1 : (int)Math.Ceiling(result.TotalCount / (double)pageSize);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var claim     = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        if (claim != null) int.TryParse(claim.Value, out currentUserId);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoSearch();
    }

    private async Task DoSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm)) return;
        lastSearchTerm = searchTerm;
        currentPage    = 1;
        await LoadAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > TotalPages) return;
        currentPage = page;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading    = true;
        hasSearched  = true;
        StateHasChanged();
        result    = await Mediator.Send(new SearchDocumentsQuery(lastSearchTerm!, currentUserId, currentPage, pageSize));
        isLoading = false;
    }

    private static string FormatSize(long bytes) =>
        bytes switch
        {
            < 1_024     => $"{bytes} B",
            < 1_048_576 => $"{bytes / 1_024.0:F1} KB",
            _           => $"{bytes / 1_048_576.0:F1} MB"
        };
}
